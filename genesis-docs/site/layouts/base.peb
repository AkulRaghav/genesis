<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page.title }} | Genesis</title>
    {% if page.description %}
    <meta name="description" content="{{ page.description }}">
    {% endif %}
    <style>
        :root { --accent: #2563eb; --bg: #fff; --text: #1a1a1a; --muted: #6b7280; --border: #e5e7eb; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: var(--text); max-width: 800px; margin: 0 auto; padding: 2rem 1rem; line-height: 1.7; }
        nav { display: flex; gap: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem; }
        nav a { color: var(--text); text-decoration: none; font-weight: 500; }
        nav a:first-child { font-weight: 700; color: var(--accent); margin-right: auto; }
        h1,h2,h3 { margin-top: 2rem; margin-bottom: 0.75rem; }
        h1 { font-size: 2rem; }
        p { margin-bottom: 1rem; }
        a { color: var(--accent); }
        code { background: #f3f4f6; padding: 0.15rem 0.4rem; border-radius: 3px; font-size: 0.9em; }
        pre { background: #1e293b; color: #e2e8f0; padding: 1.25rem; border-radius: 6px; overflow-x: auto; margin: 1.5rem 0; }
        pre code { background: none; padding: 0; color: inherit; }
        table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
        th, td { border: 1px solid var(--border); padding: 0.5rem 0.75rem; text-align: left; }
        th { background: #f9fafb; }
        ul, ol { margin: 1rem 0; padding-left: 1.5rem; }
        footer { margin-top: 4rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.85rem; }
    </style>
</head>
<body>
    <nav>
        <a href="/">Genesis</a>
        <a href="/docs/quick-start/">Docs</a>
        <a href="/docs/plugins/">Plugins</a>
        <a href="/docs/configuration/">Config</a>
    </nav>
    <main>
        {% block content %}
        {{ content | raw }}
        {% endblock %}
    </main>
    <footer>
        <p>Genesis — A modern static site generator for the JVM. Built with Genesis.</p>
    </footer>
</body>
</html>
